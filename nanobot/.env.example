# Xiaomi Account Credentials
# Copy this file to .env and fill in your credentials
# DO NOT commit .env to version control!

# Your Xiaomi account ID (numeric ID, not phone number)
XIAOMI_USER_ID=your_user_id_here

# Your Xiaomi password
XIAOMI_PASSWORD=your_password_here

# Your device ID (optional - will be fetched from account if not provided)
XIAOMI_DID=your_device_id_here
